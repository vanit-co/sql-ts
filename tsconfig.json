{
  "compilerOptions": {
    "target": "ES2022"
    ,"strict": true
    ,"incremental": true
    ,"esModuleInterop": true
    ,"moduleResolution": "bundler"
    ,"declaration": true
    ,"noEmit": false
    ,"emitDeclarationOnly": false
    ,"outDir": "./dist"
  }
  ,"include": ["./src"]
  ,"exclude": [
    "node_modules"
    ,"dist"
  ]
}
